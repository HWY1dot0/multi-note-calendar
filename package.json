{
  "name": "calendar-hub",
  "version": "0.1.10",
  "description": "Find every note created on a given day from one calendar view, no matter which folder it lives in.",
  "author": "HWY1dot0",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "lint": "svelte-check && tsc --noEmit && eslint . --ext .ts",
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/jest": "26.0.22",
    "@types/node": "16.18.126",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "esbuild": "0.25.5",
    "esbuild-svelte": "0.7.4",
    "eslint": "8.57.1",
    "jest": "26.6.3",
    "moment": "2.29.4",
    "obsidian": "^1.13.0",
    "svelte-check": "3.8.6",
    "svelte-jester": "1.3.2",
    "svelte-preprocess": "4.10.7",
    "ts-jest": "26.5.4",
    "typescript": "4.9.5",
    "svelte": "3.59.2",
    "tslib": "2.1.0"
  },
  "jest": {
    "moduleNameMapper": {
      "^obsidian-calendar-ui$": "<rootDir>/vendor/obsidian-calendar-ui/index.js",
      "^obsidian-daily-notes-interface$": "<rootDir>/vendor/obsidian-daily-notes-interface/index.js",
      "src/(.*)": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.svelte$": [
        "svelte-jester",
        {
          "preprocess": true
        }
      ],
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": [
      "js",
      "ts",
      "svelte"
    ]
  }
}
